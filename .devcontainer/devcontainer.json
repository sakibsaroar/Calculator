{
  "name": "JavaFX Java 17",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17",
      "installMaven": "true",
      "jdkDistro": "ms"
    },
    "ghcr.io/devcontainers/features/desktop-lite:1": {
      "version": "latest",
      "vncPassword": "vscode"
    }
  },
  "remoteEnv": {
    "DISPLAY": ":1"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "shrey150.javafx-support"
      ]
    }
  },
  "forwardPorts": [6080, 5901],
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y --no-install-recommends openbox libgl1-mesa-glx libgl1-mesa-dri xvfb libgtk-3-0 libxtst6 libxi6 libxrender1 libxrandr2 libfontconfig1"
}
